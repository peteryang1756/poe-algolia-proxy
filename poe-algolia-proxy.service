[Unit]
Description=Poe API + Algolia MCP Proxy
After=network.target

[Service]
Type=simple
User=exedev
WorkingDirectory=/home/exedev/api
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=UPSTREAM_API_BASE_URL=https://api.zyloo.io/v1
Environment=DEFAULT_MODEL=zyloo/kimi-k2
ExecStart=/home/exedev/node/bin/node /home/exedev/api/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
